# =============================================================================
# Vértice Invest — Exemplo de variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA versione o `.env` real. NUNCA commite segredos.
# =============================================================================

## Configurações do Servidor
PORT=5000
NODE_ENV=development

# (Opcional) Desabilita verificação de certificado TLS para BCB/scraping.
# Mantenha VAZIO/false (seguro). Use 'true' SOMENTE se o ambiente de
# hospedagem falhar na cadeia de certificados do BCB.
ALLOW_INSECURE_TLS=

## Segurança (JWT)
# Gere chaves fortes e distintas. Sugestão:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

## Criptografia em repouso (AES-256-GCM)
# Usado para cifrar mfaSecret e CPF no MongoDB. Obrigatório se MFA estiver ativo.
# Gerar com: openssl rand -hex 32. Esta chave é a "v1" (base / blind index).
ENCRYPTION_KEY=
# (S1.6) Rotação de chaves — opcional. Chaves adicionais versionadas no formato
# "v2=<64hex>;v3=<64hex>". Mantenha as antigas enquanto houver dados cifrados com elas.
ENCRYPTION_KEYS=
# (S1.6) Qual chave cifra NOVOS valores (default v1). Aponte para v2/v3 após rotacionar.
ENCRYPTION_KEY_ACTIVE=

## Banco de Dados (MongoDB Atlas)
# Formato: mongodb+srv://<user>:<password>@<cluster>/?appName=...
MONGO_URI=

## Monitoramento (Sentry) — https://sentry.io
SENTRY_DSN=
VITE_SENTRY_DSN=

## Email (SMTP)
# Para testes: https://ethereal.email ou App Password do Gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@verticeinvest.com

## API Gemini (Google) — https://aistudio.google.com/app/apikey
API_KEY=

## BRAPI — https://brapi.dev (token de dados de mercado BR)
BRAPI_TOKEN=

## Mercado Pago — https://www.mercadopago.com.br/developers
# Access token de PRODUÇÃO (use o TEST-... em desenvolvimento)
MP_ACCESS_TOKEN=
# Obtido no Dashboard MP > Webhooks. Obrigatório para validar a assinatura.
MP_WEBHOOK_SECRET=

## URLs (sem barra final)
CLIENT_URL=https://verticeinvest.com.br
API_URL=https://verticeinvest.com.br

# =============================================================================
# Parâmetros operacionais (M9) — opcionais. Se vazios, usam os defaults do
# código (server/config/financialConstants.js). Permitem ajuste sem deploy.
# =============================================================================
# Threshold global de recomendação: score >= valor → BUY (default 70).
BUY_THRESHOLD=
# Máximo de criptos por perfil no draft competitivo (default 3).
MAX_CRYPTO_PER_PROFILE=
# Janela de cache de cotações de mercado, em minutos (default 20).
MARKET_CACHE_MINUTES=
# Selic/CDI de fallback quando não há valor no SystemConfig nem na API do BC (default 11.25).
DEFAULT_SELIC_FALLBACK=
