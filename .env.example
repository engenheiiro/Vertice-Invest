# =============================================================================
# Vértice Invest — Exemplo de variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA versione o `.env` real. NUNCA commite segredos.
# =============================================================================

## Configurações do Servidor
PORT=5000
NODE_ENV=development

# (Opcional) Desabilita verificação de certificado TLS para BCB/scraping.
# Mantenha VAZIO/false (seguro). Use 'true' SOMENTE se o ambiente de
# hospedagem falhar na cadeia de certificados do BCB.
ALLOW_INSECURE_TLS=

## Segurança (JWT)
# Gere chaves fortes e distintas. Sugestão:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

## Banco de Dados (MongoDB Atlas)
# Formato: mongodb+srv://<user>:<password>@<cluster>/?appName=...
MONGO_URI=

## Monitoramento (Sentry) — https://sentry.io
SENTRY_DSN=
VITE_SENTRY_DSN=

## Email (SMTP)
# Para testes: https://ethereal.email ou App Password do Gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@verticeinvest.com

## API Gemini (Google) — https://aistudio.google.com/app/apikey
API_KEY=

## BRAPI — https://brapi.dev (token de dados de mercado BR)
BRAPI_TOKEN=

## Mercado Pago — https://www.mercadopago.com.br/developers
# Access token de PRODUÇÃO (use o TEST-... em desenvolvimento)
MP_ACCESS_TOKEN=
# Obtido no Dashboard MP > Webhooks. Obrigatório para validar a assinatura.
MP_WEBHOOK_SECRET=

## URLs (sem barra final)
CLIENT_URL=https://verticeinvest.com.br
API_URL=https://verticeinvest.com.br
