# Pre-commit: barreira contra vazamento de segredos
# 1) Bloqueia qualquer arquivo .env (exceto .env.example) entrando no commit
# 2) Roda gitleaks nos arquivos staged, se estiver instalado localmente

staged="$(git diff --cached --name-only --diff-filter=ACM)"

# 1) Nunca permitir commitar arquivos .env reais
blocked="$(printf '%s\n' "$staged" | grep -E '(^|/)\.env($|\.)' | grep -vE '\.env\.example$' || true)"
if [ -n "$blocked" ]; then
  echo "✖ Commit bloqueado: arquivo(s) de ambiente detectado(s):"
  printf '   %s\n' "$blocked"
  echo "  Remova do stage (git restore --staged <arquivo>) — segredos não devem ser versionados."
  exit 1
fi

# 2) Scan de segredos com gitleaks (se disponível)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config .gitleaks.toml || {
    echo "✖ gitleaks encontrou possíveis segredos nos arquivos staged."
    exit 1
  }
fi

# 3) Lint dos arquivos staged (eslint --fix). Requer a toolchain Node completa.
#    Ambientes restritos (ex.: GitHub Desktop no Windows) não expõem `bash` ao
#    hook e a cadeia do npx falha (código 127). Nesses casos, pulamos com aviso —
#    o CI roda o ESLint completo em cada push, então o enforcement é mantido.
if command -v bash >/dev/null 2>&1 && command -v npx >/dev/null 2>&1; then
  npx lint-staged
else
  echo "ℹ husky: ambiente sem bash/npx (ex.: GitHub Desktop) — pulando lint-staged."
  echo "  Os segredos já foram verificados acima; o ESLint roda no CI."
fi
