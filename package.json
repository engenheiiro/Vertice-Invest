
{
  "name": "vertice-invest-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "npm run dev --prefix server",
    "setup": "npm install && npm install --prefix client && npm install --prefix server",
    "build": "npm run build:client",
    "build:client": "npm install --prefix client --include=dev && npm run build --prefix client",
    "start": "node server/index.js",
    "seed:admin": "node server/scripts/seedAdmin.js",
    "seed:market": "node server/scripts/seedMarketData.js",
    "sync:prod": "node server/scripts/syncProdData.js",
    "sync:TimeSeriesWorker": "node server/scripts/syncTimeSeries.js",
    "migrate:fix": "node server/scripts/migrateHardcodedData.js",
    "test": "vitest",
    "test:backtest": "node server/scripts/runBacktestEngine.js",
    "test:client": "npm run test --prefix client",
    "test:server": "npm run test --prefix server",
    "test:ingestion": "npm run test --prefix server -- tests/ingestion.spec.js",
    "test:regression": "npm run test:regression --prefix server",
    "test:fundamentus": "npm run test:fundamentus --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
