    "react-player": "^2.16.0",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vertice-invest-root": "file:..",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
